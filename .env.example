AWS_REGION=us-east-2
S3_BUCKET_NAME=qrify-web-platform-storage-dev
# From Secrets Manager / ESO in cluster (Terraform writes this):
# DATABASE_URL=postgresql://qrify:...@qrify-postgres-dev....rds.amazonaws.com:5432/qrify
# Cognito (infra → qrify/<env>/qrify-cognito):
# COGNITO_REGION=us-east-2
# COGNITO_USER_POOL_ID=us-east-2_xxx
# COGNITO_CLIENT_ID=xxx
# COGNITO_DOMAIN=qrify-web-dev.auth.us-east-2.amazoncognito.com
# COGNITO_ISSUER=https://cognito-idp.us-east-2.amazonaws.com/us-east-2_xxx
# Optional for local-only (prefer AWS CLI / profile / IRSA in cluster):
# AWS_ACCESS_KEY=
# AWS_SECRET_KEY=
